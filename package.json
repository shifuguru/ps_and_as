{
  "name": "ps_and_as",
  "version": "1.0.60",
  "main": "index.ts",
  "scripts": {
    "start": "node ./scripts/expo-dev-env.js",
    "server": "node server/index.js",
    "start:server": "node server/index.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "node ./scripts/sync-readme-public.js && node ./scripts/expo-dev-env.js --web",
    "build:web": "expo export --platform web --output-dir web-build && node ./scripts/fix-web-build-paths.js",
    "test-core": "ts-node ./scripts/test-core.ts",
    "test-edge": "npx tsx ./scripts/test-edge-cases.ts",
    "test-runs": "tsx ./scripts/test-run-detection.ts",
    "bump-version": "node ./scripts/bump-version.js",
    "test-multiplayer": "node ./scripts/test-multiplayer.mjs",
    "qa-chaos": "node ./scripts/qa/run-chaos.mjs",
    "test-cpu-stall": "node ./scripts/test-cpu-stall-botopn.mjs",
    "test-release-gate": "node ./scripts/test-release-gate.mjs",
    "test-release-gate:offline": "node ./scripts/test-release-gate.mjs --offline",
    "qa-league": "node ./scripts/qa/run-league.mjs",
    "qa-league:watch": "node ./scripts/qa/run-league.mjs --watch 30 --minutes 10",
    "print-game-budget": "npx tsx ./scripts/print-game-budget.ts"
  },
  "dependencies": {
    "@expo-google-fonts/pinyon-script": "^0.4.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.4.9",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/stack": "^7.4.10",
    "cors": "^2.8.5",
    "expo": "~54.0.18",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.7",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-font": "~14.0.11",
    "expo-game-center": "^1.0.1",
    "expo-haptics": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "express": "^4.21.2",
    "marked": "^15.0.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.3",
    "react-native-svg": "^15.14.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@types/react": "~19.1.0"
  },
  "private": true
}
