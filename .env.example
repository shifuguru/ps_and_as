# Game server URL for native apps (Expo Go / dev builds).
# - Web dev ignores this and uses the Metro proxy automatically.
# - Native dev with Railway/ngrok: set a public https URL — it takes priority over LAN.
# - Native dev with local server: use localhost or omit; Expo LAN host is used automatically.
#
# Railway example (also set the same value as a GitHub Actions repository variable
# for GitHub Pages builds — Settings → Secrets and variables → Actions → Variables):
# EXPO_PUBLIC_SERVER_URL=https://your-production-service.up.railway.app
EXPO_PUBLIC_SERVER_URL=http://localhost:4000

# Development game server (deploy-web-dev.yml) — use a separate Railway service
# on the develop branch so testers do not share rooms/state with live players.
# EXPO_PUBLIC_SERVER_URL_DEV=https://your-dev-service.up.railway.app
